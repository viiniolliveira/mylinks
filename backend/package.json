{
  "name": "backend",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "db:push": "bunx --bun prisma db push",
    "db:generate": "bunx --bun prisma generate",
    "db:seed": "bunx --bun prisma db seed",
    "docker:build": "docker build -t mylinks-backend .",
    "docker:run": "docker run --env-file .env -p 8000:8000 mylinks-backend"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "hono": "^4.12.0",
    "install": "^0.13.0",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "prisma": "^7.4.1"
  }
}